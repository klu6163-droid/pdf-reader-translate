{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "MVP 默认权限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:window:allow-close",
    "dialog:default",
    "dialog:allow-open",
    "shell:default",
    "store:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "backend", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "backend", "sidecar": true, "args": true }
      ]
    }
  ]
}
